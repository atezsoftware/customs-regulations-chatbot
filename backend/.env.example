# local | development | test | production — controls JWT_SECRET enforcement,
# the dev auth-bypass, and whether file uploads are enabled (NODE_ENV=local
# only; see src/common/env.ts and src/common/auth/current-user.ts).
NODE_ENV=local

PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=customs_dev
DB_PASSWORD=change-me-dev
DB_NAME=customs_dev

JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Where uploaded directory files are stored on disk.
STORAGE_ROOT=./storage
