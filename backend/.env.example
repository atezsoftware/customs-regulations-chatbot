# development | test | production — controls both JWT_SECRET enforcement and
# the dev auth-bypass (see src/common/auth/current-user.ts).
NODE_ENV=development

PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=customs_dev
DB_PASSWORD=change-me-dev
DB_NAME=customs_dev

JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Where uploaded directory files are stored on disk.
STORAGE_ROOT=./storage
