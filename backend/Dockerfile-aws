# Build from repository root:
#   docker build -f backend/Dockerfile-aws -t customs-regulations-backend .
FROM node:22-slim AS build

WORKDIR /app/backend

COPY backend/package*.json ./
RUN npm ci

COPY backend/tsconfig.json ./
COPY backend/src ./src
RUN npm run build

FROM node:22-slim

WORKDIR /app

# Shared SQL migrations (node-pg-migrate) — run by entrypoint.sh at container start.
COPY db/package*.json ./db/
COPY db/.node-pg-migraterc.json ./db/
RUN cd db && npm ci

COPY db/migrations ./db/migrations/

WORKDIR /app/backend

COPY backend/package*.json ./
RUN npm ci --omit=dev

COPY --from=build /app/backend/dist ./dist

WORKDIR /app

COPY backend/entrypoint.sh ./entrypoint.sh
RUN chmod +x ./entrypoint.sh

ENV NODE_ENV=production
ENV HOST=0.0.0.0
ENV PORT=3000

EXPOSE 3000

CMD ["/app/entrypoint.sh"]
