# Build from repository root:
#   docker build -f core/Dockerfile-aws -t customs-regulations-core .
#
# Builds the api (chat/agent) service — the one the existing CI/CD workflow
# deploys. The indexer service has its own Dockerfile-aws at
# core/indexer/Dockerfile-aws, not wired into any workflow yet.
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONUTF8=1 \
    UV_PROJECT_ENVIRONMENT=/app/.venv

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY core/pyproject.toml core/uv.lock ./
COPY core/shared/pyproject.toml shared/pyproject.toml
COPY core/api/pyproject.toml api/pyproject.toml
COPY core/indexer/pyproject.toml indexer/pyproject.toml
RUN uv sync --frozen --no-dev --package fs-explorer-api --no-install-workspace

COPY core/shared/src shared/src
COPY core/api/src api/src
RUN uv sync --frozen --no-dev --package fs-explorer-api

EXPOSE 8000

CMD ["/app/.venv/bin/uvicorn", "fs_explorer_api.server:app", "--host", "0.0.0.0", "--port", "8000"]
