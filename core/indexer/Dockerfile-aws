# Build from repository root:
#   docker build -f core/indexer/Dockerfile-aws -t customs-regulations-indexer .
FROM python:3.12-slim AS builder

ENV PYTHONUNBUFFERED=1 \
    PYTHONUTF8=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    UV_PROJECT_ENVIRONMENT=/app/.venv

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY core/pyproject.toml core/uv.lock ./
COPY core/shared/pyproject.toml shared/pyproject.toml
COPY core/api/pyproject.toml api/pyproject.toml
COPY core/indexer/pyproject.toml indexer/pyproject.toml
RUN uv sync --frozen --no-dev --package fs-explorer-indexer --no-install-workspace \
    && find /app/.venv -type d -name __pycache__ -prune -exec rm -rf '{}' + \
    && find /app/.venv -type f \( -name '*.pyc' -o -name '*.pyo' -o -name '*.a' \) -delete \
    && rm -rf /app/.venv/lib/python*/site-packages/torch/include

COPY core/shared/src shared/src
COPY core/indexer/src indexer/src
RUN uv sync --frozen --no-dev --package fs-explorer-indexer \
    && find /app/.venv -type d -name __pycache__ -prune -exec rm -rf '{}' + \
    && find /app/.venv -type f \( -name '*.pyc' -o -name '*.pyo' -o -name '*.a' \) -delete \
    && rm -rf /app/.venv/lib/python*/site-packages/torch/include

FROM python:3.12-slim AS runtime

ENV PYTHONUNBUFFERED=1 \
    PYTHONUTF8=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PATH="/app/.venv/bin:$PATH"

WORKDIR /app

COPY --from=builder /app /app

EXPOSE 8001

CMD ["/app/.venv/bin/uvicorn", "fs_explorer_indexer.indexer_server:app", "--host", "0.0.0.0", "--port", "8001"]
