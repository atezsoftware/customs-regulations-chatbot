# Copy to .env and fill in your values.
# This file is for running the indexer standalone from your local machine.

# --- Gemini API key (required) ---
GOOGLE_API_KEY=

# --- Database (required) ---
# Local dev:
#   DATABASE_URL=postgresql://customs_dev:change-me-dev@localhost:5432/customs_dev
# Production (via SSH tunnel — first run: ssh -L 5432:localhost:5432 user@prod-host):
#   DATABASE_URL=postgresql://prod_user:prod_pass@localhost:5432/prod_db
DATABASE_URL=

# --- Auth token (must match CORE_INTERNAL_TOKEN on the backend) ---
# Leave blank if running without token gating (local only).
CORE_INTERNAL_TOKEN=

# --- Optional tuning ---
# FS_EXPLORER_LANGEXTRACT_MODEL=gemini-3-flash-preview
# FS_EXPLORER_LANGEXTRACT_MAX_CHARS=6000
