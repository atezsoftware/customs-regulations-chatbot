# Build from repository root:
#   docker build -f frontend/Dockerfile-aws \
#     --build-arg VITE_API_URL=https://dev-customs-regulations-api.singlewindow.io \
#     -t customs-regulations-ui .
FROM node:22-slim AS build

WORKDIR /app

ARG VITE_API_URL=https://dev-customs-regulations-api.singlewindow.io
ENV VITE_API_URL=${VITE_API_URL}

COPY frontend/package*.json ./
RUN npm ci

COPY frontend/ ./
RUN npm run build

FROM node:22-slim

WORKDIR /app

RUN npm install -g serve@14.2.4

COPY --from=build /app/dist ./dist

ENV NODE_ENV=production
ENV HOST=0.0.0.0
ENV PORT=4173

EXPOSE 4173

CMD ["serve", "-s", "dist", "-l", "tcp://0.0.0.0:4173"]
