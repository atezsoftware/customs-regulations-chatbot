# Default chat provider: OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
FS_EXPLORER_LLM_PROVIDER=openrouter
OPENROUTER_DEFAULT_MODEL=google/gemini-3-flash-preview
OPENROUTER_CATALOG_SYNC_MINUTES=60
# Optional but recommended for provider analytics/routing policies.
# OPENROUTER_HTTP_REFERER=http://localhost:5173
# OPENROUTER_APP_TITLE=Customs Regulations Chatbot

# Optional Gemini key for indexing or fallback flows.
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_api_key_here

# Optional: dedicated key for langextract metadata mode.
# If unset, indexing will fall back to GOOGLE_API_KEY.
# LANGEXTRACT_API_KEY=your_api_key_here

# Optional: override langextract model used by `explore index --with-metadata`.
# FS_EXPLORER_LANGEXTRACT_MODEL=gemini-3-flash-preview
