# Single reference for everything needed to run the whole stack locally in dev.
# Copy to `.env` (core reads it for GOOGLE_API_KEY), to `backend/.env`
# (backend reads DB_*/JWT_*/STORAGE_ROOT), and to `frontend/.env`
# (frontend reads VITE_API_URL). `scripts/run.sh --env dev` assumes this has
# already been done.

NODE_ENV=local

# --- core (Python AI engine, split into two services) ---
# OpenRouter is the default chat provider.
OPENROUTER_API_KEY=
FS_EXPLORER_LLM_PROVIDER=openrouter
OPENROUTER_DEFAULT_MODEL=google/gemini-3-flash-preview
OPENROUTER_CATALOG_SYNC_MINUTES=60
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=Customs Regulations Chatbot (Local Dev)

# Optional if you still want Gemini available for indexing or direct fallback.
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
CORE_INTERNAL_TOKEN=dev-internal-token
# core-indexer also reads FS_EXPLORER_LANGEXTRACT_MODEL/FS_EXPLORER_LANGEXTRACT_MAX_CHARS
# (optional, see core/CLAUDE.md) for the langextract metadata extraction step.


# --- db (must match db/.env.dev) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=customs_dev
DB_PASSWORD=change-me-dev
DB_NAME=customs_dev
DATABASE_URL=postgresql://customs_dev:change-me-dev@localhost:5432/customs_dev

# --- backend auth ---
# In local, auth/* still works normally, but every OTHER endpoint treats
# requests as a fixed dev user automatically (no login required), and file
# uploads are enabled — this only happens when NODE_ENV=local. Required
# (real auth, uploads disabled) in development/test/prod.
JWT_SECRET=dev-only-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# --- backend file storage ---
STORAGE_ROOT=./storage
PORT=3000
# core-api: chat/agent service (/ws/explore, /api/search)
CORE_INTERNAL_URL=ws://127.0.0.1:8000
# core-indexer: Docling/langextract indexing service (/api/index*)
CORE_INDEXER_URL=http://127.0.0.1:8001

# --- frontend ---
VITE_API_URL=http://localhost:3000
