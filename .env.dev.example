# Single reference for everything needed to run the whole stack locally in dev.
# Copy to `.env` (core reads it for GOOGLE_API_KEY), to `backend/.env`
# (backend reads DB_*/JWT_*/STORAGE_ROOT), and to `frontend/.env`
# (frontend reads VITE_API_URL). `scripts/run.sh --env dev` assumes this has
# already been done.

NODE_ENV=development

# --- core (Python AI engine) ---
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
CORE_INTERNAL_TOKEN=dev-internal-token


# --- db (must match db/.env.dev) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=customs_dev
DB_PASSWORD=change-me-dev
DB_NAME=customs_dev
DATABASE_URL=postgresql://customs_dev:change-me-dev@localhost:5432/customs_dev

# --- backend auth ---
# In development, auth/* still works normally, but every OTHER endpoint
# treats requests as a fixed dev user automatically (no login required) —
# this only happens when NODE_ENV=development. Required in test/prod.
JWT_SECRET=dev-only-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# --- backend file storage ---
STORAGE_ROOT=./storage
PORT=3000
CORE_INTERNAL_URL=ws://127.0.0.1:8000

# --- frontend ---
VITE_API_URL=http://localhost:3000
